# ---- Judge Service Environment Variables ----

# Port the HTTP server listens on (injected by Pterodactyl/Pelican)
PORT=3000

# API key for authenticating requests to /judge.
# If set, all requests (except GET /health) must include header:
#   x-api-key: <this value>
# or
#   Authorization: Bearer <this value>
# Leave empty to disable authentication (NOT recommended in production).
JUDGE_API_KEY=

# Maximum number of judge jobs running in parallel (default 3).
# Lower this on resource-constrained hosting.
JUDGE_MAX_CONCURRENT=3
